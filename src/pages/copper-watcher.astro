---
import Layout from '../layouts/Layout.astro';
import { PRICING, trialSentence } from '../data/pricing';

const SITE_URL = 'https://artificialigknorance.com';
const APP_STORE_URL = 'https://apps.apple.com/us/app/copper-watcher-cu/id6757655923';
const APP_ICON = '/images/copper-watcher-icon.webp';
const p = PRICING['copper-watcher'];

const faqs = [
    {
        q: 'What is Copper Watcher?',
        a: 'Copper Watcher is the iPhone app for copper investors, scrap dealers, electricians, and metal traders. It tracks the live copper spot price, top copper ETFs (CPER, COPX, COPP) and futures, prediction markets, a smarter sentiment badge, the Dr Copper signal vs the S&P 500, a scrap calculator, and a portfolio with realized profit tracking.'
    },
    {
        q: 'How is the copper spot price tracked?',
        a: 'Spot copper updates throughout the trading day with a live heartbeat indicator. Historical charts cover 1D, 1W, 1M, 3M, 1Y, 5Y, and ALL. Switch between line and dot chart styles, or rotate your iPhone for immersive fullscreen charts.'
    },
    {
        q: 'What is the Dr Copper signal?',
        a: '"Dr. Copper" is the old market nickname for copper\'s ability to predict the broader economy — when copper turns, the S&P 500 often follows. Copper Watcher gives you a live read of that relationship, plotted so you can see when copper is leading or trailing the market.'
    },
    {
        q: 'How does the realized profit work when I sell?',
        a: 'When you sell a position, record the sale price and date — Copper Watcher logs the realized gain and rolls it into a running cumulative profit across all of your closed positions. Gifts can be marked separately so they don\'t inflate the profit number.'
    },
    {
        q: 'What are Prediction Markets?',
        a: 'A live read of Polymarket bets on the forces driving copper — China manufacturing, data-center buildout, industrial production, recession risk — pulled into a section of the Charts tab.'
    },
    {
        q: 'What does the Smarter Sentiment badge do?',
        a: 'A Bullish / Bearish / Neutral indicator that blends short-term price momentum, the health of the 50-day trend, and the tone of recent news headlines into one signal.'
    },
    {
        q: 'How does the scrap calculator work?',
        a: 'Enter the weight and pick the copper grade — from OFHC lab grade (100%) down to #2 copper scrap (95%) — and Copper Watcher gives you the value at the current spot price. Built-in labels for every commercial purity level so you can quote a customer instantly.'
    },
    {
        q: 'Can I track my own copper holdings?',
        a: 'Yes. The portfolio tracker manages holdings in oz, g, kg, lb, or tonne. Track purchase price, live P&L per position, and the running realized profit on closed positions. Mark gifts separately so they don\'t inflate the profit number.'
    },
    {
        q: 'What currencies are supported?',
        a: 'Ten: CAD, USD, EUR, GBP, INR, AUD, CHF, JPY, CNY, and HKD. Pick one and the entire app switches.'
    },
    {
        q: 'What does Premium cost?',
        a: `Free to download. The Portfolio, What-If, and Calculator tabs are unlocked with a Copper Watcher subscription at ${p.monthly} per month or ${p.yearly} per year. ${trialSentence('copper-watcher')}`
    }
];

const pageStructuredData = {
    '@context': 'https://schema.org',
    '@graph': [
                {
            '@type': 'BreadcrumbList',
            itemListElement: [
                { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL + '/' },
                { '@type': 'ListItem', position: 2, name: 'Copper Watcher', item: SITE_URL + '/copper-watcher/' }
            ]
        },
        {
            '@type': 'FAQPage',
            mainEntity: faqs.map(({ q, a }) => ({
                '@type': 'Question',
                name: q,
                acceptedAnswer: { '@type': 'Answer', text: a }
            }))
        }
    ]
};
---

<Layout
    title="Copper Watcher — Live Copper Spot, Dr Copper Signal, Prediction Markets"
    description="Live copper spot price, ETFs (CPER, COPX, COPP), futures, the Dr Copper signal vs S&P 500, Polymarket prediction markets, sentiment badge, scrap calculator, and portfolio with realized P&L. Free iPhone app for copper investors, scrap dealers, electricians, and traders."
    ogImage={APP_ICON}
    twitterCard="summary_large_image"
    smartAppId="6757655923"
    datePublished="2026-05-08"
    mainEntityId={SITE_URL + "/#copper-watcher"}
>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(pageStructuredData)} />

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="text-sm text-gray-400 pt-6">
        <ol class="flex items-center gap-2">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-gray-300">Copper Watcher</li>
        </ol>
    </nav>

    <!-- Hero -->
    <section class="relative py-12 sm:py-16">
        <div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute top-10 left-10 w-32 h-32 bg-amber-400 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-40 h-40 bg-orange-400 rounded-full blur-3xl"></div>
        </div>

        <div class="relative flex flex-col md:flex-row items-center gap-8 md:gap-12">
            <img src={APP_ICON} alt="Copper Watcher app icon" width="180" height="180" class="w-32 h-32 md:w-44 md:h-44 rounded-3xl shadow-2xl flex-shrink-0" />
            <div class="flex-1 text-center md:text-left">
                <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-3 bg-gradient-to-r from-amber-400 to-orange-300 bg-clip-text text-transparent">
                    Copper Watcher (Cu)
                </h1>
                <p class="text-xl sm:text-2xl text-amber-300 font-medium mb-4">Live copper prices, in your pocket.</p>
                <p class="text-gray-300 max-w-2xl mb-6 text-lg">
                    Live copper spot price, ETFs and futures, the Dr Copper signal vs the S&amp;P 500, prediction
                    markets, a smarter sentiment badge, a scrap calculator, and portfolio tracking with realized
                    profit — built for copper investors, scrap dealers, electricians, and metal traders.
                </p>
                <div class="flex flex-wrap gap-3 justify-center md:justify-start">
                    <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick badges -->
    <section class="flex flex-wrap gap-2 justify-center md:justify-start mb-12">
        <span class="px-3 py-1 bg-amber-500/20 text-amber-300 rounded-full text-sm">Live spot + heartbeat</span>
        <span class="px-3 py-1 bg-amber-500/20 text-amber-300 rounded-full text-sm">CPER · COPX · COPP</span>
        <span class="px-3 py-1 bg-amber-500/20 text-amber-300 rounded-full text-sm">Dr Copper signal</span>
        <span class="px-3 py-1 bg-amber-500/20 text-amber-300 rounded-full text-sm">Scrap calculator</span>
        <span class="px-3 py-1 bg-amber-500/20 text-amber-300 rounded-full text-sm">Prediction markets</span>
        <span class="px-3 py-1 bg-amber-500/20 text-amber-300 rounded-full text-sm">Smarter sentiment</span>
    </section>

    <!-- What it does -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">What it does</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-amber-300">Live spot price + heartbeat</h3>
                <p class="text-gray-300">Spot copper updated through the trading day with a live heartbeat indicator. Historical charts (1D, 1W, 1M, 3M, 1Y, 5Y, ALL), line or dot styles, rotate for fullscreen.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-amber-300">Copper ETFs &amp; futures</h3>
                <p class="text-gray-300">Live prices for CPER, COPX, COPP and other top copper ETFs, plus futures contracts. Daily changes and full price history alongside spot.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-amber-300">Dr Copper signal</h3>
                <p class="text-gray-300">A live read on copper's relationship to the S&amp;P 500 — the classic "Dr. Copper" indicator that has predicted recessions and recoveries. Plotted so you can see when copper is leading or trailing the market.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-amber-300">Scrap calculator</h3>
                <p class="text-gray-300">Value copper by weight and purity instantly. Built-in grades from OFHC lab grade (100%) down to #2 copper scrap (95%), with labels for every commercial level.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-amber-300">Portfolio with realized P&amp;L</h3>
                <p class="text-gray-300">Holdings in oz, g, kg, lb, or tonne. Live P&amp;L per position, gifts flagged separately, and realized profit logged across every closed position when you record a sale.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-amber-300">Prediction markets</h3>
                <p class="text-gray-300">Live Polymarket bets on the forces driving copper — China manufacturing, data-center buildout, industrial production, recession risk — pulled into a section of the Charts tab.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-amber-300">Smarter sentiment</h3>
                <p class="text-gray-300">A Bullish / Bearish / Neutral badge that blends short-term momentum, 50-day trend health, and news-headline tone into one signal.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-amber-300">What-If calculator</h3>
                <p class="text-gray-300">See what a past copper position would be worth today. Compare returns against the S&amp;P 500 and copper ETFs with overlay charts. Lump-sum or dollar-cost averaging.</p>
            </div>
        </div>
    </section>

    <!-- See it in action -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-3 text-center md:text-left">See it in action</h2>
        <p class="text-gray-400 mb-8 text-center md:text-left text-sm">Real screens from the App Store. (Sample data shown.)</p>

        <!-- Mobile: horizontal snap-scroll. Desktop: 3-column grid (clean 2x3 for 6 screenshots). -->
        <div class="flex snap-x snap-mandatory overflow-x-auto gap-4 -mx-6 px-6 pb-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-2 sm:gap-6 sm:overflow-visible lg:grid-cols-3">
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/copper-watcher/spot-price.webp" type="image/webp" /><img
                    src="/images/screenshots/copper-watcher/spot-price.jpg"
                    alt="Copper Watcher live Cu Spot Price C$7.8932 down 1.12 percent, day range C$7.8713 to C$8.0137, Cu Price chart over 1Y, time period selector with 1D 1W 1M 3M 1Y 5Y ALL, and Copper ETFs list — CPER United States Copper Index Fund C$48.86, COPX Global X Copper Miners ETF C$107.68, JJC iPath A Series B Bloomberg C$26.78"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-amber-300 font-semibold text-sm">Always current spot price</figcaption>
                <p class="text-xs text-gray-400 mt-1">Cu spot, day range, full chart from 1D to all-time, gold/silver ratio context, and top ETFs.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/copper-watcher/what-if.webp" type="image/webp" /><img
                    src="/images/screenshots/copper-watcher/what-if.jpg"
                    alt="Copper Watcher What If calculator — investment amount C$2,500, time period selector showing 1Y, 2Y, 5Y, 10Y ago options, Compare Against ETF chips for COPX, COPP, MCX:COPPER, and SPY benchmark, and an Investment Growth comparison chart"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-amber-300 font-semibold text-sm">What If — past copper investment</figcaption>
                <p class="text-xs text-gray-400 mt-1">Pick an amount, a year, and Copper Watcher shows what that position would be worth today.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/copper-watcher/compare-returns.webp" type="image/webp" /><img
                    src="/images/screenshots/copper-watcher/compare-returns.jpg"
                    alt="Copper Watcher Investment Growth chart with overlays showing Cu plus 40.1 percent, SPY plus 30.8 percent, and COPP plus 59.2 percent over the period, with Your Investment Today C$3,503.46 from C$2,500 invested at copper price C$5.6332, copper purchased 443.7963 oz, current price C$7.8943, gain plus C$1,003.46"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-amber-300 font-semibold text-sm">Returns vs SPY and ETFs</figcaption>
                <p class="text-xs text-gray-400 mt-1">Overlay Copper, the S&P 500, and copper ETFs over the same window — see who actually won.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/copper-watcher/portfolio.webp" type="image/webp" /><img
                    src="/images/screenshots/copper-watcher/portfolio.jpg"
                    alt="Copper Watcher Portfolio screen — total value C$1,656.40 from 209.8221 oz total, holdings list including 2 oz, 64g, 4kg, and a 2.4kg melted wire holding each with their live value, plus an Add Holding button"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-amber-300 font-semibold text-sm">Stash Manager</figcaption>
                <p class="text-xs text-gray-400 mt-1">Track holdings in oz, g, kg, lb, or tonne — with live total value and per-position cost basis.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/copper-watcher/scrap-calc.webp" type="image/webp" /><img
                    src="/images/screenshots/copper-watcher/scrap-calc.jpg"
                    alt="Copper Watcher Calculate scrap value screen — weight 1.3 kg, purity grades grid showing 100% OFHC Lab Grade, 99.99% OFE Cathode, 99.95% ETP Wire Grade, 99.9% Bare Bright Scrap, 99.5% Fire Refined, 99% Commercial Grade selected, 98% #1 Copper Scrap, 97% General Engineering, 95% #2 Copper Scrap; estimated value C$326.86"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-amber-300 font-semibold text-sm">Built for scrap dealers</figcaption>
                <p class="text-xs text-gray-400 mt-1">Pick weight and grade — OFHC lab grade through #2 scrap — and quote a customer in seconds.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/copper-watcher/currencies.webp" type="image/webp" /><img
                    src="/images/screenshots/copper-watcher/currencies.jpg"
                    alt="Copper Watcher Settings currency picker showing 12 supported currencies — Canadian Dollar selected, US Dollar, Euro, British Pound, Indian Rupee, Australian Dollar, Japanese Yen, Swiss Franc, Chinese Yuan, Hong Kong Dollar, Singapore Dollar, Brazilian Real, plus a Premium upgrade option"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-amber-300 font-semibold text-sm">Your currency, your price</figcaption>
                <p class="text-xs text-gray-400 mt-1">CAD, USD, EUR, GBP, INR, AUD, CHF, JPY, CNY, HKD, SGD, BRL — pick one and the entire app switches.</p>
            </figure>
        </div>
    </section>

    <!-- Built for -->
    <section class="mb-16 bg-gradient-to-br from-amber-500/10 to-orange-500/10 backdrop-blur-sm rounded-3xl p-6 md:p-10 border border-amber-400/20">
        <h2 class="text-3xl font-bold mb-6 text-center">Built for copper</h2>
        <p class="text-gray-300 text-lg max-w-3xl mx-auto text-center mb-6">
            Most metals apps treat copper as an afterthought. Copper Watcher was built specifically for the people who
            buy, sell, scrap, or stack the red metal — with the calculators and currency support that real traders need.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
            <div class="text-center"><div class="text-amber-300 font-semibold">Investors</div></div>
            <div class="text-center"><div class="text-amber-300 font-semibold">Scrap dealers</div></div>
            <div class="text-center"><div class="text-amber-300 font-semibold">Electricians</div></div>
            <div class="text-center"><div class="text-amber-300 font-semibold">Metal traders</div></div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">Frequently asked questions</h2>
        <div class="space-y-3">
            {faqs.map(({ q, a }) => (
                <details class="bg-white/5 rounded-xl p-5 group hover:bg-white/10 transition-all">
                    <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-lg">
                        <span>{q}</span>
                        <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </summary>
                    <p class="mt-3 text-gray-300">{a}</p>
                </details>
            ))}
        </div>
    </section>

    <!-- Other watcher apps — internal links to the rest of the metals lineup -->
    <section class="mb-12 text-center text-sm text-gray-400">
        <p>
            Also from Artificial Igknorance:
            <a href="/gold-watcher/" class="text-yellow-300 hover:text-yellow-200 underline">Gold Watcher</a> for precious-metals stackers, ·
            <a href="/silver-watcher/" class="text-slate-300 hover:text-slate-200 underline">Silver Watcher</a> for stackers and sterling, ·
            <a href="/lithium-watcher/" class="text-teal-300 hover:text-teal-200 underline">Lithium Watcher</a> for the EV market.
        </p>
    </section>

    <!-- Final CTA -->
    <section class="text-center mb-16 bg-gradient-to-br from-amber-500/15 to-orange-500/15 rounded-3xl p-8 md:p-12 border border-amber-400/20">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Get Copper Watcher</h2>
        <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">Free download on the App Store. Built for iPhone, designed for the copper market.</p>
        <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
        <p class="mt-6 text-sm text-gray-400">Or browse <a href="/" class="text-amber-300 hover:text-amber-200 underline">all Artificial Igknorance apps</a>.</p>
    </section>
</Layout>
