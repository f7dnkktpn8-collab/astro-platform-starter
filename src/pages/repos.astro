---
import Layout from '../layouts/Layout.astro';

const username = 'artificial-igknorance';
let repos: any[] = [];
let error = '';

try {
    const response = await fetch(`https://api.github.com/users/${username}/repos?sort=updated&per_page=30`, {
        headers: {
            'Accept': 'application/vnd.github.v3+json',
            'User-Agent': 'astro-platform-starter',
        },
    });
    if (!response.ok) {
        error = `GitHub API returned ${response.status}: ${response.statusText}`;
    } else {
        repos = await response.json();
    }
} catch (e: any) {
    error = e.message || 'Failed to fetch repositories';
}
---

<Layout title="Our Repositories - Artificial Igknorance">
    <div class="py-10 sm:py-16">
        <div class="text-center mb-12">
            <h1 class="text-4xl sm:text-5xl font-bold mb-4 bg-gradient-to-r from-blue-400 via-cyan-300 to-purple-400 bg-clip-text text-transparent">
                Our Repositories
            </h1>
            <p class="text-lg text-gray-300">
                Open source projects from <span class="text-cyan-400 font-semibold">{username}</span>
            </p>
        </div>

        {error && (
            <div class="bg-red-500/20 border border-red-400/30 text-red-300 rounded-xl p-4 mb-8 text-center">
                {error}
            </div>
        )}

        {repos.length === 0 && !error && (
            <p class="text-center text-gray-400">No repositories found.</p>
        )}

        <div class="grid gap-6 md:grid-cols-2">
            {repos.map((repo) => (
                <a
                    href={repo.html_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block bg-white/5 backdrop-blur-sm rounded-2xl p-6 hover:bg-white/10 transition-all duration-300 border border-white/5 hover:border-white/15"
                >
                    <div class="flex items-start justify-between gap-3 mb-3">
                        <h2 class="text-xl font-bold text-blue-300 truncate">{repo.name}</h2>
                        {repo.private && (
                            <span class="px-2 py-0.5 bg-yellow-500/20 border border-yellow-400/30 text-yellow-300 rounded-full text-xs font-medium flex-shrink-0">
                                Private
                            </span>
                        )}
                    </div>

                    {repo.description && (
                        <p class="text-gray-300 text-sm mb-4 line-clamp-2">{repo.description}</p>
                    )}

                    <div class="flex flex-wrap gap-3 text-xs text-gray-400">
                        {repo.language && (
                            <span class="flex items-center gap-1">
                                <span class="w-2.5 h-2.5 rounded-full bg-cyan-400 inline-block"></span>
                                {repo.language}
                            </span>
                        )}
                        {repo.stargazers_count > 0 && (
                            <span>&#9733; {repo.stargazers_count}</span>
                        )}
                        {repo.forks_count > 0 && (
                            <span>&#128268; {repo.forks_count}</span>
                        )}
                        <span class="ml-auto">
                            Updated {new Date(repo.updated_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                        </span>
                    </div>
                </a>
            ))}
        </div>

        <div class="text-center mt-12">
            <a href="/" class="text-cyan-400 hover:text-cyan-300 transition-colors">
                &larr; Back to Home
            </a>
        </div>
    </div>
</Layout>
