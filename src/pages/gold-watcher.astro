---
import Layout from '../layouts/Layout.astro';
import { PRICING, trialSentence } from '../data/pricing';

const SITE_URL = 'https://artificialigknorance.com';
const APP_STORE_URL = 'https://apps.apple.com/us/app/gold-watcher-au/id6758283387';
const APP_ICON = '/images/gold-watcher-icon.webp';
const p = PRICING['gold-watcher'];

const faqs = [
    {
        q: 'What is Gold Watcher?',
        a: 'Gold Watcher is the iPhone app for gold investors, jewelers, and precious-metals enthusiasts. It tracks the live gold spot price, top gold ETFs (GLD, IAU, SGOL) and futures, the gold/silver ratio, prediction markets, a smarter sentiment badge, seasonal patterns, a karat calculator, and a karat-aware portfolio with realized profit tracking.'
    },
    {
        q: 'How is the gold spot price tracked?',
        a: 'Gold Watcher pulls the live gold spot price during trading hours with a live heartbeat indicator. Historical charts cover 1D, 1W, 1M, 3M, 1Y, 5Y, and ALL. Switch between line and dot chart styles, or rotate your iPhone for an immersive landscape view.'
    },
    {
        q: 'What is "karat-aware" portfolio tracking?',
        a: 'When you log a 14K or 18K piece, Gold Watcher prices it correctly against pure gold instead of treating it like 24K. So your gold-coin holding and your 14K bracelet sit in the same portfolio with both showing the real live value.'
    },
    {
        q: 'How does the realized profit work when I sell?',
        a: 'When you sell a position, record the sale price and date — Gold Watcher logs the realized gain and rolls it into a running cumulative profit across all of your closed positions. Gifts can be marked separately so they don\'t inflate the profit number.'
    },
    {
        q: 'What are Prediction Markets?',
        a: 'A live read of Polymarket bets on the macro forces that move gold — Fed rate cuts, inflation, recession risk, central-bank reserves — pulled into a section of the Charts tab. A market view, not a chart view.'
    },
    {
        q: 'What does the Smarter Sentiment badge do?',
        a: 'A Bullish / Bearish / Neutral indicator that blends short-term price momentum, the health of the 50-day trend, and the tone of recent news headlines into one signal — instead of just reflecting today\'s price change.'
    },
    {
        q: 'How does the karat calculator work?',
        a: 'Enter weight and karat — every karat from 24K pure (.999 fine) down to 9K, with fineness labels at each level — and Gold Watcher gives you the value at the current spot price. Useful for jewelers quoting a customer or anyone selling scrap gold.'
    },
    {
        q: 'What is the gold/silver ratio and why does it matter?',
        a: 'The gold/silver ratio is how many ounces of silver one ounce of gold buys. It tells precious-metals investors when one metal is historically expensive or cheap relative to the other. Gold Watcher tracks the live ratio with the historical average for context.'
    },
    {
        q: 'What currencies are supported?',
        a: 'Ten: CAD, USD, EUR, GBP, INR, AUD, CHF, JPY, CNY, and HKD. Pick one and the entire app switches.'
    },
    {
        q: 'What does Premium cost?',
        a: `Free to download. The Portfolio, What-If, and Calculator tabs are unlocked with a Gold Watcher subscription at ${p.monthly} per month or ${p.yearly} per year. ${trialSentence('gold-watcher')}`
    }
];

const pageStructuredData = {
    '@context': 'https://schema.org',
    '@graph': [
                {
            '@type': 'BreadcrumbList',
            itemListElement: [
                { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL + '/' },
                { '@type': 'ListItem', position: 2, name: 'Gold Watcher', item: SITE_URL + '/gold-watcher/' }
            ]
        },
        {
            '@type': 'FAQPage',
            mainEntity: faqs.map(({ q, a }) => ({
                '@type': 'Question',
                name: q,
                acceptedAnswer: { '@type': 'Answer', text: a }
            }))
        }
    ]
};
---

<Layout
    title="Gold Watcher — Live Gold Spot Price, Karat-Aware Portfolio, Prediction Markets"
    description="Live gold spot price, ETFs (GLD, IAU, SGOL), futures, gold/silver ratio, karat-aware portfolio with realized P&L, Polymarket prediction markets, sentiment badge, seasonal patterns, and karat calculator. Free iPhone app for gold investors and jewelers."
    ogImage={APP_ICON}
    twitterCard="summary_large_image"
    smartAppId="6758283387"
    datePublished="2026-05-08"
    mainEntityId={SITE_URL + "/#gold-watcher"}
>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(pageStructuredData)} />

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="text-sm text-gray-400 pt-6">
        <ol class="flex items-center gap-2">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-gray-300">Gold Watcher</li>
        </ol>
    </nav>

    <!-- Hero -->
    <section class="relative py-12 sm:py-16">
        <div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute top-10 left-10 w-32 h-32 bg-yellow-400 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-40 h-40 bg-amber-400 rounded-full blur-3xl"></div>
        </div>

        <div class="relative flex flex-col md:flex-row items-center gap-8 md:gap-12">
            <img src={APP_ICON} alt="Gold Watcher app icon" width="180" height="180" class="w-32 h-32 md:w-44 md:h-44 rounded-3xl shadow-2xl flex-shrink-0" />
            <div class="flex-1 text-center md:text-left">
                <h1 class="text-4xl sm:text-5xl font-bold mb-3 bg-gradient-to-r from-yellow-400 to-amber-300 bg-clip-text text-transparent">
                    Gold Watcher (Au)
                </h1>
                <p class="text-xl sm:text-2xl text-yellow-300 font-medium mb-4">Serious gold tools, no learning curve.</p>
                <p class="text-gray-300 max-w-2xl mb-6 text-lg">
                    Live gold spot price, ETFs and futures, the gold/silver ratio, prediction markets, a smarter
                    sentiment badge, seasonal patterns, and a karat-aware portfolio with realized profit tracking —
                    built for gold investors, jewelers, and precious-metals enthusiasts.
                </p>
                <div class="flex flex-wrap gap-3 justify-center md:justify-start">
                    <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick badges -->
    <section class="flex flex-wrap gap-2 justify-center md:justify-start mb-12">
        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-300 rounded-full text-sm">Home screen widget</span>
        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-300 rounded-full text-sm">Live spot + Today&apos;s Pulse</span>
        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-300 rounded-full text-sm">GLD · IAU · SGOL + miners</span>
        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-300 rounded-full text-sm">Karat-aware portfolio</span>
        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-300 rounded-full text-sm">Gold/silver &amp; BTC/gold ratios</span>
        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-300 rounded-full text-sm">Real interest rate signal</span>
        <span class="px-3 py-1 bg-yellow-500/20 text-yellow-300 rounded-full text-sm">Signals · news + Polymarket</span>
    </section>

    <!-- What it does -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">What it does</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
            <div class="sm:col-span-2 bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <div class="flex items-center gap-2 mb-2">
                    <h3 class="text-xl font-bold text-yellow-300">Home screen widget</h3>
                    <span class="px-2 py-0.5 bg-yellow-500/20 text-yellow-300 rounded-full text-xs font-semibold uppercase tracking-wide">New</span>
                </div>
                <p class="text-gray-300">Add a small or medium widget for the live gold spot price, today&apos;s change, and a 7-day chart — right on your home screen, in your selected currency. It refreshes through the day without opening the app.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-yellow-300">Live spot + Today&apos;s Pulse</h3>
                <p class="text-gray-300">Spot gold updated through the trading day with a heartbeat indicator. Today&apos;s Pulse gives you a one-sentence read on what&apos;s actually moving — new highs, big moves, streaks, moving-average crosses — generated from live data. Charts from 1D through 10Y and MAX, line or dot styles, rotate for fullscreen.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-yellow-300">ETFs, futures &amp; miners</h3>
                <p class="text-gray-300">Live prices and history for GLD, IAU, SGOL and other top gold ETFs. Gold futures contracts. Top gold mining stocks with live quotes — a different angle on gold exposure beyond the metal itself.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-yellow-300">Karat-aware portfolio</h3>
                <p class="text-gray-300">Holdings in oz, g, kg, dwt, tola, tael, or grain. 14K and 18K pieces priced correctly against pure gold. Live P&amp;L per position, gifts flagged separately, and realized profit logged across every closed position.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-yellow-300">Karat calculator</h3>
                <p class="text-gray-300">Value gold instantly by weight and karat. Every karat from 24K pure (.999 fine) down to 9K, with fineness labels at every level — built for jewelers.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-yellow-300">Signals</h3>
                <p class="text-gray-300">Live financial news from Reuters, Bloomberg, Kitco, MarketWatch and more — each with the publisher&apos;s logo. Plus live Polymarket prediction-market odds on the macro forces moving gold: Fed rate cuts, inflation, recession risk, central-bank reserves.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-yellow-300">Key ratios</h3>
                <p class="text-gray-300">Gold/silver ratio with adaptive timeframe (1Y, 5Y, 10Y, MAX) and dated x-axis. BTC/gold ratio for hard-money sentiment. Real Interest Rate indicator (treasury rate minus inflation expectations) — the single best macro signal for gold.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-yellow-300">Smarter sentiment</h3>
                <p class="text-gray-300">A Bullish / Bearish / Neutral badge that blends short-term momentum, 50-day trend health, and news-headline tone into one signal — not just today&apos;s price change.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-yellow-300">What-If calculator</h3>
                <p class="text-gray-300">See what your gold would be worth today if you&apos;d bought at any past date. Compare returns against the S&amp;P 500 and any gold ETF with overlay charts. Toggle between lump-sum and dollar-cost-averaging with detailed DCA breakdowns.</p>
            </div>
        </div>
    </section>

    <!-- See it in action -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-3 text-center md:text-left">See it in action</h2>
        <p class="text-gray-400 mb-8 text-center md:text-left text-sm">Real screens from the App Store. (Sample data shown.)</p>

        <!-- Mobile: horizontal snap-scroll. Desktop: 2-column then 3-column grid. -->
        <div class="flex snap-x snap-mandatory overflow-x-auto gap-4 -mx-6 px-6 pb-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-2 sm:gap-6 sm:overflow-visible lg:grid-cols-3">
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/gold-watcher/spot-price.webp" type="image/webp" /><img
                    src="/images/screenshots/gold-watcher/spot-price.jpg"
                    alt="Gold Watcher Au Spot Price C$6,233.74 per ounce down 0.34 percent, day range C$6,214.36 to C$6,262.25, Today's Pulse card reading Gold is +33.6 percent over the past year, and Au Price chart over a 1Y timeframe"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-yellow-300 font-semibold text-sm">Live spot + Today&apos;s Pulse</figcaption>
                <p class="text-xs text-gray-400 mt-1">Au spot with day range, a one-sentence Today&apos;s Pulse read on what&apos;s actually moving, and the full chart.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/gold-watcher/portfolio.webp" type="image/webp" /><img
                    src="/images/screenshots/gold-watcher/portfolio.jpg"
                    alt="Gold Watcher Portfolio screen — Total Value C$781,496.68 across 125.50 ounces, Total Profit/Loss +C$605,303.68 (+343.5 percent), a Portfolio Value Over Time bar chart, and individual holdings listed below"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-yellow-300 font-semibold text-sm">Karat-aware portfolio</figcaption>
                <p class="text-xs text-gray-400 mt-1">Total value, realized profit on closed positions, 14K and 18K priced correctly against pure gold.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/gold-watcher/dca.webp" type="image/webp" /><img
                    src="/images/screenshots/gold-watcher/dca.jpg"
                    alt="Gold Watcher Dollar-Cost Average screen — Invested On 2Y ago, Compare Against ETF chips GLD/IAU/SGOL/BAR, Lump Sum vs DCA toggle on with 24 monthly contributions of C$104.15, and a comparison chart showing Lump Sum +91.9 percent vs SPY +43.9 percent"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-yellow-300 font-semibold text-sm">Lump-sum or DCA</figcaption>
                <p class="text-xs text-gray-400 mt-1">Pick an amount and a date, then compare lump-sum vs dollar-cost-averaging against any gold ETF.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/gold-watcher/investment-detail.webp" type="image/webp" /><img
                    src="/images/screenshots/gold-watcher/investment-detail.jpg"
                    alt="Gold Watcher detail view of a DCA investment — Your Investment Today C$4,795.96 up 91.9 percent, Invested C$2,499.65, Gold price then C$3,246.99, Gold purchased 0.7698 oz, current Gold price C$6,233.02, Gain/Loss +C$2,296.30, and a full Dollar-Cost Averaging breakdown"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-yellow-300 font-semibold text-sm">Investment detail</figcaption>
                <p class="text-xs text-gray-400 mt-1">Drill into any past investment to see exactly how lump-sum vs DCA played out.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/gold-watcher/compare-spy.webp" type="image/webp" /><img
                    src="/images/screenshots/gold-watcher/compare-spy.jpg"
                    alt="Gold Watcher compare chart on the Spot tab showing GDXJ, SPY and SGOL price growth from March 2 through Mar 2 over a five-year period, with a Gold ETFs list below — GLD C$468.14 down 3.23 percent and IAU C$95.92 down 3.18 percent"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-yellow-300 font-semibold text-sm">Gold vs the S&amp;P 500</figcaption>
                <p class="text-xs text-gray-400 mt-1">Overlay gold against any benchmark and any other gold ETF — see who&apos;s really winning.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/gold-watcher/real-rate-seasonal.webp" type="image/webp" /><img
                    src="/images/screenshots/gold-watcher/real-rate-seasonal.jpg"
                    alt="Gold Watcher Real Interest Rate card showing +1.96 percent (10Y Treasury 4.46 percent minus Inflation about 2.5 percent) with the note 'Positive real rates — headwind for gold', then a Seasonal Patterns 10Y AVG chart showing average monthly returns from January through December"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-yellow-300 font-semibold text-sm">Real rate + seasonal</figcaption>
                <p class="text-xs text-gray-400 mt-1">Treasury yield minus inflation — the single best macro signal for gold — plus 10-year seasonal returns.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/gold-watcher/ratios.webp" type="image/webp" /><img
                    src="/images/screenshots/gold-watcher/ratios.jpg"
                    alt="Gold Watcher key ratios — Gold/Silver Ratio 60.07 against long-term average about 65 with a 5Y chart (low 59.7, average 81.4, high 101.6), and BTC/Gold Ratio 14.81 showing ounces of gold per Bitcoin with a 5Y chart"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-yellow-300 font-semibold text-sm">Gold/Silver &amp; BTC/Gold</figcaption>
                <p class="text-xs text-gray-400 mt-1">Live gold/silver ratio in historical context plus the BTC/gold ratio for hard-money sentiment.</p>
            </figure>
        </div>
    </section>

    <!-- Built for -->
    <section class="mb-16 bg-gradient-to-br from-yellow-500/10 to-amber-500/10 backdrop-blur-sm rounded-3xl p-6 md:p-10 border border-yellow-400/20">
        <h2 class="text-3xl font-bold mb-6 text-center">Built for gold</h2>
        <p class="text-gray-300 text-lg max-w-3xl mx-auto text-center mb-6">
            Whether you're stacking, trading, quoting jewelry, or just keeping an eye on the gold/silver ratio,
            Gold Watcher gives you the data you need on one screen — in the currency and unit you actually use.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
            <div class="text-center"><div class="text-yellow-300 font-semibold">Investors</div></div>
            <div class="text-center"><div class="text-yellow-300 font-semibold">Jewelers</div></div>
            <div class="text-center"><div class="text-yellow-300 font-semibold">Stackers</div></div>
            <div class="text-center"><div class="text-yellow-300 font-semibold">Coin collectors</div></div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">Frequently asked questions</h2>
        <div class="space-y-3">
            {faqs.map(({ q, a }) => (
                <details class="bg-white/5 rounded-xl p-5 group hover:bg-white/10 transition-all">
                    <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-lg">
                        <span>{q}</span>
                        <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </summary>
                    <p class="mt-3 text-gray-300">{a}</p>
                </details>
            ))}
        </div>
    </section>

    <!-- Other watcher apps — internal links to the rest of the metals lineup -->
    <section class="mb-12 text-center text-sm text-gray-400">
        <p>
            Also from Artificial Igknorance:
            <a href="/silver-watcher/" class="text-slate-300 hover:text-slate-200 underline">Silver Watcher</a> for stackers and sterling, ·
            <a href="/copper-watcher/" class="text-amber-300 hover:text-amber-200 underline">Copper Watcher</a> for industrial-metals investors, ·
            <a href="/lithium-watcher/" class="text-teal-300 hover:text-teal-200 underline">Lithium Watcher</a> for the EV market.
        </p>
    </section>

    <!-- Final CTA -->
    <section class="text-center mb-16 bg-gradient-to-br from-yellow-500/15 to-amber-500/15 rounded-3xl p-8 md:p-12 border border-yellow-400/20">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Get Gold Watcher</h2>
        <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">Free download on the App Store. Built for iPhone, designed for the gold market.</p>
        <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
        <p class="mt-6 text-sm text-gray-400">Or browse <a href="/" class="text-yellow-300 hover:text-yellow-200 underline">all Artificial Igknorance apps</a>.</p>
    </section>
</Layout>
