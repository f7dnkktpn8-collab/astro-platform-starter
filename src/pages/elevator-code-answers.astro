---
import Layout from '../layouts/Layout.astro';

const SITE_URL = 'https://artificialigknorance.com';
const APP_STORE_URL = 'https://apps.apple.com/us/app/escalator-field-command/id6756789866';
const APP_ICON = '/images/escalator-field-command-icon.webp';

const faqs = [
    {
        q: 'What is the buggy switch?',
        a: 'The buggy switch, also known as the step upthrust device, is a safety device that detects upward displacement of more than 5 mm at the riser end of a step at the lower landing and stops the escalator (6.1.6.3.9). It\'s designed to prevent a step from being forced upward and causing an accident. The device must stop the escalator before the displaced step reaches the combplate under any load up to brake rated load. Always verify against the official code.'
    },
    {
        q: 'How steep can an escalator be and how fast can it run?',
        a: 'An escalator can be at an angle of no more than 30 degrees from horizontal, with a field tolerance of up to 31 degrees (6.1.3.1). The maximum speed is 0.5 m/s (100 ft/min) (6.1.4.1.1). Always verify against the official code.'
    },
    {
        q: 'Why do I have to keep the area at the top and bottom of the escalator clear?',
        a: 'That area is the safety zone, and it must be kept clear of obstacles — minimum width of the handrail-centerline distance (W) plus 200 mm (8 in.), and minimum length of twice that distance (2W), per 6.1.3.6.4. It prevents tripping hazards and keeps entry and exit safe. Anything left in the zone is a violation against the building. Always verify against the official code.'
    },
    {
        q: 'What are the yellow lines on the escalator steps for?',
        a: 'The yellow lines — called step demarcation — are visual cues showing passengers where one step ends and the next begins (6.1.3.5.6). They must be 38-50 mm (1.5-2 in.) wide on the back of each step and 13-50 mm (0.5-2 in.) wide on the sides. Always verify against the official code.'
    },
    {
        q: 'What is the emergency stop button and where is it located?',
        a: 'The emergency stop button is a red button located at the top and bottom landings, on the right side facing the escalator, covered with a transparent cover that lifts or slides aside (6.1.6.3.1). It must be marked "EMERGENCY STOP" in letters at least 12 mm (0.5 in.) high, plus "MOVE COVER" and "PUSH BUTTON." When the cover is moved, an alarm of at least 80 dBA sounds. Always verify against the official code.'
    }
];

const pageStructuredData = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'BreadcrumbList',
            itemListElement: [
                { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL + '/' },
                {
                    '@type': 'ListItem',
                    position: 2,
                    name: 'Elevator & Escalator Code Answers',
                    item: SITE_URL + '/elevator-code-answers/'
                }
            ]
        },
        // Only emit FAQPage once real questions exist — an empty mainEntity
        // array is invalid structured data.
        ...(faqs.length > 0
            ? [{
                '@type': 'FAQPage',
                mainEntity: faqs.map(({ q, a }) => ({
                    '@type': 'Question',
                    name: q,
                    acceptedAnswer: { '@type': 'Answer', text: a }
                }))
            }]
            : [])
    ]
};
---

<Layout
    title="Elevator & Escalator Code Answers — A17.1, A17.2, B44, A17.3 Explained"
    description="Plain-language answers to common elevator and escalator code questions: ASME A17.1, A17.2, CSA B44, A17.3, Category 1 testing, SSPI compliance, and Maintenance Control Programs — explained simply, no binder required."
    ogImage={APP_ICON}
    twitterCard="summary_large_image"
    smartAppId="6756789866"
    datePublished="2026-07-02"
    mainEntityId={SITE_URL + "/#escalator-field-command"}
>
    <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(pageStructuredData)}
    />

    <!-- Breadcrumb (visual + crawlable) -->
    <nav aria-label="Breadcrumb" class="text-sm text-gray-400 pt-6">
        <ol class="flex items-center gap-2">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-gray-300">Elevator &amp; Escalator Code Answers</li>
        </ol>
    </nav>

    <!-- Hero -->
    <section class="relative py-12 sm:py-16">
        <div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute top-10 left-10 w-32 h-32 bg-blue-400 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-40 h-40 bg-cyan-400 rounded-full blur-3xl"></div>
        </div>

        <div class="relative text-center max-w-3xl mx-auto">
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-3 bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent">
                Elevator &amp; Escalator Code Answers
            </h1>
            <p class="text-xl sm:text-2xl text-blue-300 font-medium mb-4">
                A17.1, A17.2, A17.3, and B44 — explained in plain language.
            </p>
            <p class="text-gray-300 max-w-2xl mx-auto text-lg">
                Quick, plain-English answers to the elevator and escalator code questions mechanics,
                inspectors, and building owners actually search for — no binder, no jargon, no login required.
            </p>
        </div>
    </section>

    <!-- Quick badges -->
    <section class="flex flex-wrap gap-2 justify-center mb-12">
        <span class="px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm">ASME A17.1</span>
        <span class="px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm">ASME A17.2</span>
        <span class="px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm">CSA B44</span>
        <span class="px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm">ASME A17.3</span>
        <span class="px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm">Category 1 testing</span>
        <span class="px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm">SSPI compliance</span>
        <span class="px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm">Maintenance Control Program</span>
    </section>

    <!-- FAQ (hidden until questions are supplied) -->
    {faqs.length > 0 && (
        <section class="mb-16">
            <h2 class="text-3xl font-bold mb-8 text-center md:text-left">Common code questions, answered</h2>
            <div class="space-y-3">
                {
                    faqs.map(({ q, a }) => (
                        <details class="bg-white/5 rounded-xl p-5 group hover:bg-white/10 transition-all">
                            <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-lg">
                                <span>{q}</span>
                                <svg
                                    class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-300 group-open:rotate-180"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"
                                    />
                                </svg>
                            </summary>
                            <p class="mt-3 text-gray-300">{a}</p>
                        </details>
                    ))
                }
            </div>
        </section>
    )}

    <!-- CTA: funnel to Escalator Field Command -->
    <section class="text-center mb-16 bg-gradient-to-br from-blue-500/15 to-cyan-500/15 rounded-3xl p-8 md:p-12 border border-blue-400/20">
        <img
            src={APP_ICON}
            alt="Escalator Field Command app icon"
            width="96"
            height="96"
            class="w-20 h-20 rounded-2xl shadow-xl mx-auto mb-6"
            loading="lazy"
        />
        <h2 class="text-2xl sm:text-3xl font-bold mb-4">Need these answers on the job, not at a desk?</h2>
        <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
            Escalator Field Command's built-in Field Guide gives you plain-language, sourced code
            answers right at the unit — no signal required. Ask a question the way you'd ask a
            senior mechanic and get a clear answer citing the exact code section, drawn from
            ASME A17.1, A17.2, CSA B44, and the MCP.
        </p>
        <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
        <p class="mt-6 text-sm text-gray-400">
            Or <a href="/escalator-field-command/" class="text-blue-300 hover:text-blue-200 underline">learn more about Escalator Field Command</a>.
        </p>
    </section>
</Layout>
