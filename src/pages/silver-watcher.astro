---
import Layout from '../layouts/Layout.astro';

const SITE_URL = 'https://artificialigknorance.com';
const APP_STORE_URL = 'https://apps.apple.com/us/app/silver-watcher-ag/id6760270695';
const APP_ICON = '/images/silver-watcher-icon.webp';

const faqs = [
    {
        q: 'What is Silver Watcher?',
        a: 'Silver Watcher is the iPhone app for silver stackers, coin collectors, and precious-metals investors. It tracks the live silver spot price, top silver ETFs (SLV, SIVR, PSLV) and futures, the gold/silver ratio with buy/sell signals, seasonal patterns, a purity calculator, full portfolio tracking, and price alerts in 12 currencies.'
    },
    {
        q: 'How does the gold/silver ratio work in Silver Watcher?',
        a: 'The app tracks the gold-to-silver ratio in real time with a full 5-year historical chart. You see the current ratio against its low, average, and high — and built-in buy/sell signals tell you when silver is historically cheap or expensive relative to gold.'
    },
    {
        q: 'What are the seasonal patterns?',
        a: 'A 10-year average monthly return chart shows which months silver historically performs best and worst. Helps you time purchases with data instead of guesswork — especially useful for stackers building a position over time.'
    },
    {
        q: 'How does the purity calculator work?',
        a: 'Enter weight and pick the silver grade — from Fine Silver (999) down to European (800), including Sterling (925), Britannia (958), and Coin Silver (900) — and Silver Watcher gives you the value at the current spot price.'
    },
    {
        q: 'Can I track my own silver holdings?',
        a: 'Yes. The portfolio tracker manages holdings in oz, g, kg, dwt, tola, tael, or grain. Track purchase price per unit, profit and loss, and holding duration on every position. Tap any holding to edit. Mark gifted silver separately.'
    },
    {
        q: 'What currencies are supported?',
        a: 'Twelve: CAD, USD, EUR, GBP, INR, AUD, JPY, CHF, CNY, HKD, SGD, and BRL. Pick one and the entire app — spot price, ETFs, ratio, portfolio, alerts — switches to it.'
    },
    {
        q: 'How much does it cost?',
        a: 'Free to download from the App Store. See the latest pricing and any in-app options on the App Store listing.'
    }
];

const pageStructuredData = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'WebPage',
            '@id': SITE_URL + '/silver-watcher/#webpage',
            url: SITE_URL + '/silver-watcher/',
            name: 'Silver Watcher — Live Silver Spot Price App for Stackers & Investors',
            description:
                'Silver Watcher tracks the live silver spot price, ETFs (SLV, SIVR, PSLV), futures, gold/silver ratio with buy/sell signals, seasonal patterns, purity calculator, portfolio tracker, alerts in 12 currencies.',
            isPartOf: { '@id': SITE_URL + '/#website' },
            mainEntity: { '@id': SITE_URL + '/#silver-watcher' },
            inLanguage: 'en-US',
            primaryImageOfPage: { '@type': 'ImageObject', url: SITE_URL + APP_ICON }
        },
        {
            '@type': 'BreadcrumbList',
            itemListElement: [
                { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL + '/' },
                { '@type': 'ListItem', position: 2, name: 'Silver Watcher', item: SITE_URL + '/silver-watcher/' }
            ]
        },
        {
            '@type': 'FAQPage',
            mainEntity: faqs.map(({ q, a }) => ({
                '@type': 'Question',
                name: q,
                acceptedAnswer: { '@type': 'Answer', text: a }
            }))
        }
    ]
};
---

<Layout
    title="Silver Watcher — Live Silver Spot Price App for Stackers & Investors"
    description="Live silver spot price, ETFs (SLV, SIVR, PSLV), futures, gold/silver ratio with buy/sell signals, seasonal patterns, purity calculator, portfolio tracker, alerts in 12 currencies. Free iPhone app."
    ogImage={APP_ICON}
    twitterCard="summary"
    smartAppId="6760270695"
>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(pageStructuredData)} />

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="text-sm text-gray-400 pt-6">
        <ol class="flex items-center gap-2">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-gray-300">Silver Watcher</li>
        </ol>
    </nav>

    <!-- Hero -->
    <section class="relative py-12 sm:py-16">
        <div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute top-10 left-10 w-32 h-32 bg-slate-300 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-40 h-40 bg-gray-300 rounded-full blur-3xl"></div>
        </div>

        <div class="relative flex flex-col md:flex-row items-center gap-8 md:gap-12">
            <img src={APP_ICON} alt="Silver Watcher app icon" width="180" height="180" class="w-32 h-32 md:w-44 md:h-44 rounded-3xl shadow-2xl flex-shrink-0" />
            <div class="flex-1 text-center md:text-left">
                <h1 class="text-4xl sm:text-5xl font-bold mb-3 bg-gradient-to-r from-slate-300 to-gray-200 bg-clip-text text-transparent">
                    Silver Watcher (Ag)
                </h1>
                <p class="text-xl sm:text-2xl text-slate-300 font-medium mb-4">Built for stackers and traders.</p>
                <p class="text-gray-300 max-w-2xl mb-6 text-lg">
                    Live silver spot price, the gold/silver ratio with buy/sell signals, seasonal patterns, ETFs and
                    futures, a purity calculator, and full portfolio tracking — across 12 currencies.
                </p>
                <div class="flex flex-wrap gap-3 justify-center md:justify-start">
                    <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick badges -->
    <section class="flex flex-wrap gap-2 justify-center md:justify-start mb-12">
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Live spot price</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">SLV · SIVR · PSLV</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Gold/silver ratio</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Seasonal patterns</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Purity calculator</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">12 currencies</span>
    </section>

    <!-- What it does -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">What it does</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Live spot price</h3>
                <p class="text-gray-300">Current silver spot price updated through the trading day, with daily change, range, and historical charts from 1 day to all-time. Rotate for landscape fullscreen.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Gold/silver ratio with signals</h3>
                <p class="text-gray-300">Live ratio with a 5-year historical chart, current value vs. low/average/high, and built-in buy/sell signals when silver is historically cheap or expensive vs. gold.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Seasonal patterns</h3>
                <p class="text-gray-300">A 10-year average monthly return chart showing which months silver historically performs best — time purchases with data, not guesswork.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Silver ETFs &amp; futures</h3>
                <p class="text-gray-300">Live prices for SLV, SIVR, PSLV and other top silver ETFs, plus silver futures contracts. Daily changes and full price history alongside spot.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Purity calculator</h3>
                <p class="text-gray-300">Value silver instantly by weight and purity. Built-in grades from Fine Silver (999) to European (800), including Sterling (925), Britannia (958), and Coin Silver (900).</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Portfolio &amp; What If</h3>
                <p class="text-gray-300">Track holdings with cost basis, P/L, and duration. Compare past returns vs. S&amp;P 500 and silver ETFs. Toggle lump-sum vs. dollar-cost averaging with a clear winner.</p>
            </div>
        </div>
    </section>

    <!-- Built for -->
    <section class="mb-16 bg-gradient-to-br from-slate-500/10 to-gray-500/10 backdrop-blur-sm rounded-3xl p-6 md:p-10 border border-slate-400/20">
        <h2 class="text-3xl font-bold mb-6 text-center">Built for silver</h2>
        <p class="text-gray-300 text-lg max-w-3xl mx-auto text-center mb-6">
            Silver investing is data-heavy — spot price, ratio, seasonality, purity grades, multiple weight units. Silver
            Watcher puts every signal in one app, in your currency and your unit of measure, with no signup or account.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
            <div class="text-center"><div class="text-slate-300 font-semibold">Stackers</div></div>
            <div class="text-center"><div class="text-slate-300 font-semibold">Coin collectors</div></div>
            <div class="text-center"><div class="text-slate-300 font-semibold">Investors</div></div>
            <div class="text-center"><div class="text-slate-300 font-semibold">Bullion dealers</div></div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">Frequently asked questions</h2>
        <div class="space-y-3">
            {faqs.map(({ q, a }) => (
                <details class="bg-white/5 rounded-xl p-5 group hover:bg-white/10 transition-all">
                    <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-lg">
                        <span>{q}</span>
                        <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </summary>
                    <p class="mt-3 text-gray-300">{a}</p>
                </details>
            ))}
        </div>
    </section>

    <!-- Final CTA -->
    <section class="text-center mb-16 bg-gradient-to-br from-slate-500/15 to-gray-500/15 rounded-3xl p-8 md:p-12 border border-slate-400/20">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Get Silver Watcher</h2>
        <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">Free download on the App Store. Built for iPhone, designed for the silver market.</p>
        <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
        <p class="mt-6 text-sm text-gray-400">Or browse <a href="/" class="text-slate-300 hover:text-slate-200 underline">all Artificial Igknorance apps</a>.</p>
    </section>
</Layout>
