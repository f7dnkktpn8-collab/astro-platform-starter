---
import Layout from '../layouts/Layout.astro';
import { PRICING, trialSentence } from '../data/pricing';

const SITE_URL = 'https://artificialigknorance.com';
const APP_STORE_URL = 'https://apps.apple.com/us/app/silver-watcher-ag/id6760270695';
const APP_ICON = '/images/silver-watcher-icon.webp';
const p = PRICING['silver-watcher'];

const faqs = [
    {
        q: 'What is Silver Watcher?',
        a: 'Silver Watcher is the iPhone app for silver stackers, coin collectors, and precious-metals investors. It tracks the live silver spot price, top silver ETFs (SLV, SIVR, PSLV) and futures, the gold/silver ratio with buy/sell signals, prediction markets, a smarter sentiment badge, seasonal patterns, a purity calculator, and a purity-aware portfolio with realized profit tracking.'
    },
    {
        q: 'How is the silver spot price tracked?',
        a: 'Spot silver updates throughout the trading day with a live heartbeat indicator. Historical charts cover 1D, 1W, 1M, 3M, 1Y, 5Y, and ALL. Switch between line and dot chart styles, or rotate your iPhone for immersive fullscreen charts.'
    },
    {
        q: 'What does "purity-aware" portfolio tracking mean?',
        a: 'When you log a Sterling (.925), Britannia (.958), or Coin Silver (.900) piece, Silver Watcher values it correctly against fine silver instead of treating it like .999. Your bullion rounds and your sterling flatware can live in the same portfolio with both showing the right live value.'
    },
    {
        q: 'How does the realized profit work when I sell?',
        a: 'When you sell a position, record the sale price and date — Silver Watcher logs the realized gain and rolls it into a running cumulative profit across all of your closed positions. Gifts can be marked separately so they don\'t inflate the profit number.'
    },
    {
        q: 'What are Prediction Markets?',
        a: 'A live read of Polymarket bets on the macro forces that move silver — Fed rate cuts, inflation, recession risk, plus solar and EV demand — pulled into a section of the Charts tab.'
    },
    {
        q: 'What does the Smarter Sentiment badge do?',
        a: 'A Bullish / Bearish / Neutral indicator that blends short-term price momentum, the health of the 50-day trend, and the tone of recent news headlines into one signal.'
    },
    {
        q: 'How does the gold/silver ratio work?',
        a: 'The app tracks the gold-to-silver ratio in real time with a full 5-year historical chart. You see the current ratio against its low, average, and high — and built-in buy/sell signals tell you when silver is historically cheap or expensive relative to gold.'
    },
    {
        q: 'How does the purity calculator work?',
        a: 'Enter weight and pick the silver grade — from Fine Silver (.999) down to European (.800), including Sterling, Britannia, and Coin Silver — and Silver Watcher gives you the value at the current spot price.'
    },
    {
        q: 'What currencies are supported?',
        a: 'Twelve: CAD, USD, EUR, GBP, INR, AUD, JPY, CHF, CNY, HKD, SGD, and BRL. Pick one and the entire app switches.'
    },
    {
        q: 'What does Premium cost?',
        a: `Free to download. The Portfolio, What-If, and Calculator tabs are unlocked with a Silver Watcher subscription at ${p.monthly} per month or ${p.yearly} per year. ${trialSentence('silver-watcher')}`
    }
];

const pageStructuredData = {
    '@context': 'https://schema.org',
    '@graph': [
                {
            '@type': 'BreadcrumbList',
            itemListElement: [
                { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL + '/' },
                { '@type': 'ListItem', position: 2, name: 'Silver Watcher', item: SITE_URL + '/silver-watcher/' }
            ]
        },
        {
            '@type': 'FAQPage',
            mainEntity: faqs.map(({ q, a }) => ({
                '@type': 'Question',
                name: q,
                acceptedAnswer: { '@type': 'Answer', text: a }
            }))
        }
    ]
};
---

<Layout
    title="Silver Watcher — Live Silver Spot, Purity-Aware Portfolio, Prediction Markets"
    description="Live silver spot price, ETFs (SLV, SIVR, PSLV), futures, gold/silver ratio with buy/sell signals, Polymarket prediction markets, sentiment badge, seasonal patterns, purity-aware portfolio with realized P&L. Free iPhone app for stackers."
    ogImage={APP_ICON}
    twitterCard="summary_large_image"
    smartAppId="6760270695"
    datePublished="2026-05-08"
    mainEntityId={SITE_URL + "/#silver-watcher"}
>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(pageStructuredData)} />

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="text-sm text-gray-400 pt-6">
        <ol class="flex items-center gap-2">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-gray-300">Silver Watcher</li>
        </ol>
    </nav>

    <!-- Hero -->
    <section class="relative py-12 sm:py-16">
        <div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute top-10 left-10 w-32 h-32 bg-slate-300 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-40 h-40 bg-gray-300 rounded-full blur-3xl"></div>
        </div>

        <div class="relative flex flex-col md:flex-row items-center gap-8 md:gap-12">
            <img src={APP_ICON} alt="Silver Watcher app icon" width="180" height="180" class="w-32 h-32 md:w-44 md:h-44 rounded-3xl shadow-2xl flex-shrink-0" />
            <div class="flex-1 text-center md:text-left">
                <h1 class="text-4xl sm:text-5xl font-bold mb-3 bg-gradient-to-r from-slate-300 to-gray-200 bg-clip-text text-transparent">
                    Silver Watcher (Ag)
                </h1>
                <p class="text-xl sm:text-2xl text-slate-300 font-medium mb-4">Built for stackers and traders.</p>
                <p class="text-gray-300 max-w-2xl mb-6 text-lg">
                    Live silver spot price with a heartbeat indicator, the gold/silver ratio with buy/sell signals,
                    prediction markets, a smarter sentiment badge, seasonal patterns, and a purity-aware portfolio
                    with realized profit tracking — across 12 currencies.
                </p>
                <div class="flex flex-wrap gap-3 justify-center md:justify-start">
                    <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick badges -->
    <section class="flex flex-wrap gap-2 justify-center md:justify-start mb-12">
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Home screen widget</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Live spot + heartbeat</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">SLV · SIVR · PSLV + miners</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Purity-aware portfolio</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Gold/silver ratio + buy/sell signal</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Signals · news + Polymarket</span>
        <span class="px-3 py-1 bg-slate-500/20 text-slate-300 rounded-full text-sm">Smarter sentiment</span>
    </section>

    <!-- What it does -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">What it does</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
            <div class="sm:col-span-2 bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <div class="flex items-center gap-2 mb-2">
                    <h3 class="text-xl font-bold text-slate-300">Home screen widget</h3>
                    <span class="px-2 py-0.5 bg-slate-500/20 text-slate-300 rounded-full text-xs font-semibold uppercase tracking-wide">New</span>
                </div>
                <p class="text-gray-300">Add a small or medium widget for the live silver spot price, today&apos;s change, and a 7-day chart — right on your home screen, in your selected currency. It refreshes through the day without opening the app.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Live spot price + heartbeat</h3>
                <p class="text-gray-300">Spot silver updated through the trading day with a live heartbeat indicator. Charts from 1D through 10Y and MAX, line or dot styles, rotate for fullscreen.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Gold/silver ratio + buy/sell signal</h3>
                <p class="text-gray-300">Live ratio with adaptive timeframe (1Y, 5Y, 10Y, MAX), dated x-axis, and current value against low/average/high. Premium adds a clean buy/sell signal that calls silver overvalued or undervalued vs gold based on the historical band.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Purity-aware portfolio</h3>
                <p class="text-gray-300">Holdings in oz, g, kg, dwt, tola, tael, or grain. Sterling (.925), Britannia (.958), and Coin Silver (.900) priced correctly against fine silver. Live P&amp;L, realized profit on closed positions, gifts flagged separately.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Purity calculator</h3>
                <p class="text-gray-300">Value silver instantly by weight and purity. Grades from Fine Silver (.999) to European (.800), including Sterling, Britannia, and Coin Silver.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Signals</h3>
                <p class="text-gray-300">Live financial news from Reuters, Bloomberg, Kitco, MarketWatch and more — each with the publisher&apos;s logo. Plus live Polymarket prediction-market odds on the forces moving silver: Fed rate cuts, inflation, recession risk, solar and EV demand.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">ETFs, futures &amp; miners</h3>
                <p class="text-gray-300">Live prices and history for SLV, SIVR, and PSLV. Silver futures contracts. Major silver mining stocks tracked alongside — another angle on silver exposure.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">Smarter sentiment</h3>
                <p class="text-gray-300">A Bullish / Bearish / Neutral badge that blends short-term momentum, 50-day trend health, and news-headline tone into one signal.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-slate-300">What-If calculator</h3>
                <p class="text-gray-300">See what your silver would be worth today if you&apos;d bought at any past date. Compare against the S&amp;P 500 and silver ETFs with overlay charts. Toggle between lump-sum and dollar-cost-averaging with detailed DCA breakdowns.</p>
            </div>
        </div>
    </section>

    <!-- See it in action -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-3 text-center md:text-left">See it in action</h2>
        <p class="text-gray-400 mb-8 text-center md:text-left text-sm">Real screens from the App Store. (Sample data shown.)</p>

        <!-- Mobile: horizontal snap-scroll. Desktop: 2-column then 3-column grid. -->
        <div class="flex snap-x snap-mandatory overflow-x-auto gap-4 -mx-6 px-6 pb-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-2 sm:gap-6 sm:overflow-visible lg:grid-cols-3">
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/silver-watcher/spot-price.webp" type="image/webp" /><img
                    src="/images/screenshots/silver-watcher/spot-price.jpg"
                    alt="Silver Watcher Ag Spot Price C$104.34 per ounce down 0.25 percent, day range C$102.60 to C$104.70, Ag Price chart, and the Gold/Silver Ratio 59.90 — with a tab bar at the bottom showing Spot, Signals, Portfolio, Calc and What If"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-slate-300 font-semibold text-sm">Live spot price</figcaption>
                <p class="text-xs text-gray-400 mt-1">Ag spot, day range, full chart, and the gold/silver ratio in context.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/silver-watcher/portfolio.webp" type="image/webp" /><img
                    src="/images/screenshots/silver-watcher/portfolio.jpg"
                    alt="Silver Watcher Portfolio screen — Total Value C$5,214.59 across 50 oz, Total Profit/Loss +C$1,394.59 (+36.5 percent) on a C$3,820 cost basis, Portfolio Value Over Time bar chart, and individual holdings (10 5oz bars at C$5,214.59) listed below"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-slate-300 font-semibold text-sm">Purity-aware portfolio</figcaption>
                <p class="text-xs text-gray-400 mt-1">Live value, cost basis, profit, and holding duration on every position.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/silver-watcher/what-if.webp" type="image/webp" /><img
                    src="/images/screenshots/silver-watcher/what-if.jpg"
                    alt="Silver Watcher Investment Backtesting screen — Compare Against ETF chips SIVR, PSLV, SIL (selected) and SPY (selected), Investment Growth chart, and Your Investment Today C$10,266.90 up 118.4 percent with Ag +118.4 percent vs SPY +27.4 percent and SIL +98.7 percent"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-slate-300 font-semibold text-sm">What If — past silver investment</figcaption>
                <p class="text-xs text-gray-400 mt-1">Pick an amount, a year, and ETFs to compare against — full gain/loss breakdown below.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/silver-watcher/ratio-signal.webp" type="image/webp" /><img
                    src="/images/screenshots/silver-watcher/ratio-signal.jpg"
                    alt="Silver Watcher Gold/Silver Ratio 59.90 against long-term average about 65 with a 5Y chart (low 59.6, average 81.4, high 101.6), and a Ratio Buy/Sell Signal card reading 'Silver Overvalued' with the note 'Silver looks historically expensive vs gold'"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-slate-300 font-semibold text-sm">Ratio + buy/sell signal</figcaption>
                <p class="text-xs text-gray-400 mt-1">Live gold/silver ratio against the historical band, with a clean over/undervalued read for Premium users.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/silver-watcher/signals.webp" type="image/webp" /><img
                    src="/images/screenshots/silver-watcher/signals.jpg"
                    alt="Silver Watcher Signals tab — 'Prediction markets and news moving silver' header, then a Prediction Markets section from Polymarket listing Fed interest-rate questions for the June 2026 meeting with vote-volume and YES odds for each"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-slate-300 font-semibold text-sm">Signals — news + Polymarket</figcaption>
                <p class="text-xs text-gray-400 mt-1">Live financial news with publisher logos plus prediction-market odds on macro forces moving silver.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/silver-watcher/seasonal-etfs.webp" type="image/webp" /><img
                    src="/images/screenshots/silver-watcher/seasonal-etfs.jpg"
                    alt="Silver Watcher Seasonal Patterns 10Y AVG chart showing average monthly returns January through December with the current month highlighted, followed by the Silver ETFs list — SLV C$94.13, SIVR C$98.91, PSLV C$33.07, SIL C$127.45 — and a Silver Miners section below"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-slate-300 font-semibold text-sm">Seasonal + ETFs + miners</figcaption>
                <p class="text-xs text-gray-400 mt-1">10-year monthly seasonal returns, then every silver ETF and the major mining stocks.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/silver-watcher/purity-calc.webp" type="image/webp" /><img
                    src="/images/screenshots/silver-watcher/purity-calc.jpg"
                    alt="Silver Watcher Calculate value screen — weight 158 g, weight unit grid showing oz, g (selected), kg, dwt, tola, tael, grain; purity grid with 999 Fine Silver, 958 Britannia, 950 French Silver, 925 Sterling (selected), 900 Coin Silver, 835 Continental, 800 European; Estimated Value C$490.53 at spot price C$104.29 per ounce"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-slate-300 font-semibold text-sm">Built for stackers and jewellers</figcaption>
                <p class="text-xs text-gray-400 mt-1">Pick weight and purity — Fine Silver, Britannia, Sterling, Coin Silver, European 800.</p>
            </figure>
        </div>
    </section>

    <!-- Built for -->
    <section class="mb-16 bg-gradient-to-br from-slate-500/10 to-gray-500/10 backdrop-blur-sm rounded-3xl p-6 md:p-10 border border-slate-400/20">
        <h2 class="text-3xl font-bold mb-6 text-center">Built for silver</h2>
        <p class="text-gray-300 text-lg max-w-3xl mx-auto text-center mb-6">
            Silver investing is data-heavy — spot price, ratio, seasonality, purity grades, multiple weight units. Silver
            Watcher puts every signal in one app, in your currency and your unit of measure, with no signup or account.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
            <div class="text-center"><div class="text-slate-300 font-semibold">Stackers</div></div>
            <div class="text-center"><div class="text-slate-300 font-semibold">Coin collectors</div></div>
            <div class="text-center"><div class="text-slate-300 font-semibold">Investors</div></div>
            <div class="text-center"><div class="text-slate-300 font-semibold">Bullion dealers</div></div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">Frequently asked questions</h2>
        <div class="space-y-3">
            {faqs.map(({ q, a }) => (
                <details class="bg-white/5 rounded-xl p-5 group hover:bg-white/10 transition-all">
                    <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-lg">
                        <span>{q}</span>
                        <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </summary>
                    <p class="mt-3 text-gray-300">{a}</p>
                </details>
            ))}
        </div>
    </section>

    <!-- Other watcher apps — internal links to the rest of the metals lineup -->
    <section class="mb-12 text-center text-sm text-gray-400">
        <p>
            Also from Artificial Igknorance:
            <a href="/gold-watcher/" class="text-yellow-300 hover:text-yellow-200 underline">Gold Watcher</a> for the gold/silver ratio play, ·
            <a href="/copper-watcher/" class="text-amber-300 hover:text-amber-200 underline">Copper Watcher</a> for industrial-metals investors, ·
            <a href="/lithium-watcher/" class="text-teal-300 hover:text-teal-200 underline">Lithium Watcher</a> for the EV market.
        </p>
    </section>

    <!-- Final CTA -->
    <section class="text-center mb-16 bg-gradient-to-br from-slate-500/15 to-gray-500/15 rounded-3xl p-8 md:p-12 border border-slate-400/20">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Get Silver Watcher</h2>
        <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">Free download on the App Store. Built for iPhone, designed for the silver market.</p>
        <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
        <p class="mt-6 text-sm text-gray-400">Or browse <a href="/" class="text-slate-300 hover:text-slate-200 underline">all Artificial Igknorance apps</a>.</p>
    </section>
</Layout>
