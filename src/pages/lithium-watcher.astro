---
import Layout from '../layouts/Layout.astro';
import { PRICING, trialSentence } from '../data/pricing';

const SITE_URL = 'https://artificialigknorance.com';
const APP_STORE_URL = 'https://apps.apple.com/us/app/lithium-watcher-li/id6761344726';
const APP_ICON = '/images/lithium-watcher-icon.webp';
const p = PRICING['lithium-watcher'];

const faqs = [
    {
        q: 'What is Lithium Watcher?',
        a: 'Lithium Watcher is the iPhone app for lithium investors and EV-market enthusiasts. It tracks the lithium price via three sources (Lithium Hydroxide CME futures, the GSCI Lithium Index, and the LIT ETF), lithium mining stocks (ALB, SQM, PLL, LAC), the major EV manufacturers (Tesla, Rivian, Lucid, NIO, XPeng, Li Auto, BYD), prediction markets, a smarter sentiment badge, seasonal patterns, and a portfolio with realized profit tracking.'
    },
    {
        q: 'How is the lithium price tracked?',
        a: 'Lithium Watcher pulls three live sources updated throughout the trading day: Lithium Hydroxide CME futures, the GSCI Lithium Index, and the LIT ETF (Global X Lithium & Battery Tech). Historical charts cover 1D, 1W, 1M, 3M, 6M, 1Y, and 5Y, switchable between line and dot styles. Rotate your iPhone for immersive fullscreen charts.'
    },
    {
        q: 'What lithium ETFs and stocks does it cover?',
        a: 'Lithium ETFs include LIT (Global X Lithium & Battery Tech) and KARS (KraneShares Electric Vehicles & Future Mobility). Mining stocks include Albemarle (ALB), Sociedad Química y Minera (SQM), Piedmont Lithium (PLL), and Lithium Americas (LAC).'
    },
    {
        q: 'What is the EV Market tab?',
        a: 'A dedicated tab tracking the major EV manufacturers — Tesla, Rivian, Lucid, NIO, XPeng, Li Auto, BYD — on a single compare chart. Each ticker gets its own fixed colour (no more red/green flipping based on direction) so you can read the chart at a glance.'
    },
    {
        q: 'How does the realized profit work when I sell?',
        a: 'When you sell a position, record the sale price and date — Lithium Watcher logs the realized gain and rolls it into a running cumulative profit across all of your closed positions. Gifts can be marked separately so they don\'t inflate the profit number.'
    },
    {
        q: 'What are Prediction Markets?',
        a: 'A live read of Polymarket bets on the forces driving lithium demand — Tesla quarterly numbers, Rivian deliveries, EV sales targets, battery supply chains — pulled into a section of the Charts tab.'
    },
    {
        q: 'What does the Smarter Sentiment badge do?',
        a: 'A Bullish / Bearish / Neutral indicator that blends short-term price momentum, the health of the 50-day trend, and the tone of recent news headlines into one signal.'
    },
    {
        q: 'What about seasonal patterns?',
        a: 'A 10-year average monthly return chart shows which months lithium has historically been strongest and weakest — useful for timing entries with data instead of guesswork.'
    },
    {
        q: 'What currencies are supported?',
        a: 'USD, CAD, EUR, GBP, AUD, JPY, CHF, CNY, INR, and more. Pick one and the entire app switches.'
    },
    {
        q: 'What does Premium cost?',
        a: `Free to download. The Portfolio and EV Market tabs are unlocked with a Lithium Watcher subscription at ${p.monthly} per month or ${p.yearly} per year. ${trialSentence('lithium-watcher')}`
    }
];

const pageStructuredData = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'BreadcrumbList',
            itemListElement: [
                { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL + '/' },
                { '@type': 'ListItem', position: 2, name: 'Lithium Watcher', item: SITE_URL + '/lithium-watcher/' }
            ]
        },
        {
            '@type': 'FAQPage',
            mainEntity: faqs.map(({ q, a }) => ({
                '@type': 'Question',
                name: q,
                acceptedAnswer: { '@type': 'Answer', text: a }
            }))
        }
    ]
};
---

<Layout
    title="Lithium Watcher — Live Lithium Price, EV Market, Prediction Markets"
    description="Track lithium via three sources (Lithium Hydroxide CME futures, GSCI Lithium Index, LIT ETF), mining stocks (ALB, SQM, PLL, LAC), and EV manufacturers (Tesla, Rivian, NIO, XPeng, BYD) on a single compare chart. Prediction markets, sentiment, seasonal patterns, and portfolio with realized P&L."
    ogImage={APP_ICON}
    twitterCard="summary_large_image"
    smartAppId="6761344726"
    datePublished="2026-05-08"
    mainEntityId={SITE_URL + "/#lithium-watcher"}
>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(pageStructuredData)} />

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="text-sm text-gray-400 pt-6">
        <ol class="flex items-center gap-2">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-gray-300">Lithium Watcher</li>
        </ol>
    </nav>

    <!-- Hero -->
    <section class="relative py-12 sm:py-16">
        <div class="absolute inset-0 opacity-10 pointer-events-none">
            <div class="absolute top-10 left-10 w-32 h-32 bg-teal-400 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-40 h-40 bg-cyan-400 rounded-full blur-3xl"></div>
        </div>

        <div class="relative flex flex-col md:flex-row items-center gap-8 md:gap-12">
            <img src={APP_ICON} alt="Lithium Watcher app icon" width="180" height="180" class="w-32 h-32 md:w-44 md:h-44 rounded-3xl shadow-2xl flex-shrink-0" />
            <div class="flex-1 text-center md:text-left">
                <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-3 bg-gradient-to-r from-teal-400 to-cyan-300 bg-clip-text text-transparent">
                    Lithium Watcher (Li)
                </h1>
                <p class="text-xl sm:text-2xl text-teal-300 font-medium mb-4">From lithium mine to the road.</p>
                <p class="text-gray-300 max-w-2xl mb-6 text-lg">
                    Lithium prices from three live sources — Lithium Hydroxide CME futures, the GSCI Lithium Index, and
                    the LIT ETF — alongside mining stocks, EV manufacturers, prediction markets, sentiment, and a
                    portfolio with realized profit tracking. Built for the EV-market wave.
                </p>
                <div class="flex flex-wrap gap-3 justify-center md:justify-start">
                    <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick badges -->
    <section class="flex flex-wrap gap-2 justify-center md:justify-start mb-12">
        <span class="px-3 py-1 bg-teal-500/20 text-teal-300 rounded-full text-sm">CME · GSCI · LIT</span>
        <span class="px-3 py-1 bg-teal-500/20 text-teal-300 rounded-full text-sm">ALB · SQM · PLL · LAC</span>
        <span class="px-3 py-1 bg-teal-500/20 text-teal-300 rounded-full text-sm">EV Market compare chart</span>
        <span class="px-3 py-1 bg-teal-500/20 text-teal-300 rounded-full text-sm">Prediction markets</span>
        <span class="px-3 py-1 bg-teal-500/20 text-teal-300 rounded-full text-sm">Smarter sentiment</span>
        <span class="px-3 py-1 bg-teal-500/20 text-teal-300 rounded-full text-sm">Seasonal patterns</span>
    </section>

    <!-- What it does -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">What it does</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-teal-300">Three live lithium prices</h3>
                <p class="text-gray-300">Lithium Hydroxide CME futures, the GSCI Lithium Index, and the LIT ETF — all updated throughout the trading day. Historical charts (1D, 1W, 1M, 3M, 6M, 1Y, 5Y), line or dot styles, rotate for fullscreen.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-teal-300">Mining stocks &amp; battery ETFs</h3>
                <p class="text-gray-300">Lithium mining stocks (ALB, SQM, PLL, LAC) alongside LIT (Global X Lithium &amp; Battery Tech) and KARS (KraneShares Electric Vehicles &amp; Future Mobility) — the full battery-and-EV supply chain in one place.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-teal-300">EV Market compare chart</h3>
                <p class="text-gray-300">Tesla, Rivian, Lucid, NIO, XPeng, Li Auto, and BYD on a single compare chart. Each ticker gets its own fixed colour — no more red/green flipping based on direction — so the chart reads at a glance.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-teal-300">Portfolio with realized P&amp;L</h3>
                <p class="text-gray-300">Track LIT, ALB, SQM, PLL, LAC, and other lithium-sector positions. Live P&amp;L per position, gifts flagged separately, and realized profit logged across every closed position when you record a sale.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-teal-300">Prediction markets</h3>
                <p class="text-gray-300">Live Polymarket bets on the forces driving lithium demand — Tesla quarterly numbers, Rivian deliveries, EV sales targets, battery supply chains — pulled into a section of the Charts tab.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-teal-300">Smarter sentiment</h3>
                <p class="text-gray-300">A Bullish / Bearish / Neutral badge that blends short-term momentum, 50-day trend health, and news-headline tone into one signal.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-teal-300">Seasonal patterns</h3>
                <p class="text-gray-300">Average monthly lithium returns over the past 10 years — see which months have historically been strongest and weakest.</p>
            </div>
            <div class="bg-white/5 rounded-2xl p-6 hover:bg-white/10 transition-all">
                <h3 class="text-xl font-bold mb-2 text-teal-300">Multi-currency</h3>
                <p class="text-gray-300">View prices in USD, CAD, EUR, GBP, AUD, JPY, CHF, CNY, INR, and more. Pick one and the entire app switches.</p>
            </div>
        </div>
    </section>

    <!-- See it in action -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-3 text-center md:text-left">See it in action</h2>
        <p class="text-gray-400 mb-8 text-center md:text-left text-sm">Real screens from the App Store. (Sample data shown.)</p>

        <!-- Mobile: horizontal snap-scroll. Desktop: 3-column grid (clean 2x3 for 5+ screenshots, last row has 2). -->
        <div class="flex snap-x snap-mandatory overflow-x-auto gap-4 -mx-6 px-6 pb-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-2 sm:gap-6 sm:overflow-visible lg:grid-cols-3">
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/lithium-watcher/markets-overview.webp" type="image/webp" /><img
                    src="/images/screenshots/lithium-watcher/markets-overview.jpg"
                    alt="Lithium Watcher Lithium Markets dashboard — Lithium Hydroxide $26.36 per kg, BSCI Lithium $192.33, LIT ETF $101.71, seasonal patterns 10Y average chart, and Lithium ETFs list with LIT $101.71, BATT $20.82, REMX $123.02 — illustrating live lithium markets in CAD"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-teal-300 font-semibold text-sm">Live lithium markets</figcaption>
                <p class="text-xs text-gray-400 mt-1">Spot prices, futures, and ETFs with seasonal-pattern context.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/lithium-watcher/mining-stocks.webp" type="image/webp" /><img
                    src="/images/screenshots/lithium-watcher/mining-stocks.jpg"
                    alt="Lithium Watcher Lithium Mining Stocks list — ALB Albemarle Corporation $240.69, SQM Sociedad Química y Minera $111.91, SGML Sigma Lithium Corporation $20.18, LAC Lithium Americas Corp $5.61, and GNENF Ganfeng Lithium Group $12.45, with a News and Sentiment feed of lithium-relevant headlines below"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-teal-300 font-semibold text-sm">Track mining stocks</figcaption>
                <p class="text-xs text-gray-400 mt-1">ALB, SQM, LAC and more in one place — plus relevant news.</p>
            </figure>
            <figure class="snap-center flex-shrink-0 w-72 sm:w-auto">
                <picture><source srcset="/images/screenshots/lithium-watcher/ev-market.webp" type="image/webp" /><img
                    src="/images/screenshots/lithium-watcher/ev-market.jpg"
                    alt="Lithium Watcher EV Market screen — performance chart comparing SPY, TSLA Tesla, RIVN Rivian over 5Y showing SPY plus 49.6 percent, TSLA plus 20.3 percent, RIVN minus 88.2 percent — plus EV ticker grid (S&P 500, TSLA, RIVN, LCID, NIO, LI, XPEV, GM, F, VWAGY, BYDDY, GTGE.F, SSNLF, DRIV, IDRV, KARS) and EV manufacturers list with TSLA C$491.05 and RIVN C$21.28"
                    width="800"
                    height="1738"
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-2xl shadow-xl border border-white/10"
                /></picture>
                <figcaption class="mt-3 text-teal-300 font-semibold text-sm">Follow the EV supply chain</figcaption>
                <p class="text-xs text-gray-400 mt-1">Tesla, Rivian, Lucid, NIO, XPeng, Li Auto, BYD — lithium meets EVs.</p>
            </figure>
        </div>
    </section>

    <!-- Built for -->
    <section class="mb-16 bg-gradient-to-br from-teal-500/10 to-cyan-500/10 backdrop-blur-sm rounded-3xl p-6 md:p-10 border border-teal-400/20">
        <h2 class="text-3xl font-bold mb-6 text-center">Built for the EV revolution</h2>
        <p class="text-gray-300 text-lg max-w-3xl mx-auto text-center mb-6">
            Lithium isn't a precious metal — it's an industrial input for the EV economy. Lithium Watcher tracks the
            full supply chain from mine to road, in one app, without bank logins or signups.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
            <div class="text-center"><div class="text-teal-300 font-semibold">Lithium investors</div></div>
            <div class="text-center"><div class="text-teal-300 font-semibold">EV enthusiasts</div></div>
            <div class="text-center"><div class="text-teal-300 font-semibold">Battery sector traders</div></div>
            <div class="text-center"><div class="text-teal-300 font-semibold">Mining-stock followers</div></div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-center md:text-left">Frequently asked questions</h2>
        <div class="space-y-3">
            {faqs.map(({ q, a }) => (
                <details class="bg-white/5 rounded-xl p-5 group hover:bg-white/10 transition-all">
                    <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-lg">
                        <span>{q}</span>
                        <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </summary>
                    <p class="mt-3 text-gray-300">{a}</p>
                </details>
            ))}
        </div>
    </section>

    <!-- Other watcher apps — internal links to the rest of the metals lineup -->
    <section class="mb-12 text-center text-sm text-gray-400">
        <p>
            Also from Artificial Igknorance:
            <a href="/gold-watcher/" class="text-yellow-300 hover:text-yellow-200 underline">Gold Watcher</a> for precious-metals stackers, ·
            <a href="/silver-watcher/" class="text-slate-300 hover:text-slate-200 underline">Silver Watcher</a> for stackers and sterling, ·
            <a href="/copper-watcher/" class="text-amber-300 hover:text-amber-200 underline">Copper Watcher</a> for industrial-metals investors.
        </p>
    </section>

    <!-- Final CTA -->
    <section class="text-center mb-16 bg-gradient-to-br from-teal-500/15 to-cyan-500/15 rounded-3xl p-8 md:p-12 border border-teal-400/20">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Get Lithium Watcher</h2>
        <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">Free download on the App Store. Built for iPhone, designed for the lithium and EV markets.</p>
        <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="inline-block transition-transform duration-200 hover:scale-105" aria-label="Download on the App Store"><img src="/images/appstore-badge.svg" alt="Download on the App Store" class="h-14 w-auto" loading="lazy" /></a>
        <p class="mt-6 text-sm text-gray-400">Or browse <a href="/" class="text-teal-300 hover:text-teal-200 underline">all Artificial Igknorance apps</a>.</p>
    </section>
</Layout>
