---
// Sticky header. On desktop (sm+) the nav links sit inline. On mobile they live
// inside a <details> panel toggled by the hamburger button — pure HTML/CSS, no
// JS, no flash-of-unstyled-content. The summary's chevron rotates on open via
// the `group-open:rotate-180` utility.
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-[#355c7d]/80 border-b border-white/10 -mx-6 sm:-mx-12 px-6 sm:px-12">
    <div class="max-w-5xl mx-auto h-14 flex items-center justify-between">
        <a href="/" class="text-lg font-bold bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent no-underline hover:opacity-100">
            Artificial Igknorance
        </a>

        <!-- Desktop nav -->
        <nav class="hidden sm:flex items-center gap-6 text-sm text-gray-300">
            <a href="/healthtrail-medical/" class="no-underline hover:text-white transition-colors">Health</a>
            <a href="/escalator-field-command/" class="no-underline hover:text-white transition-colors">Escalator</a>
            <a href="/#financial" class="no-underline hover:text-white transition-colors">Financial</a>
            <a href="/about/" class="no-underline hover:text-white transition-colors">About</a>
            <a href="/#faq" class="no-underline hover:text-white transition-colors">FAQ</a>
            <a href="/#contact" class="no-underline hover:text-white transition-colors">Contact</a>
            <!-- Other Projects dropdown — hover-triggered, pure CSS/Tailwind -->
            <div class="relative group/proj">
                <button type="button" class="flex items-center gap-1 text-gray-300 hover:text-white transition-colors cursor-default select-none">
                    Other Projects
                    <svg class="w-3 h-3 mt-px" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>
                <!-- pt-2 bridges cursor gap between button and panel so hover stays active -->
                <div class="absolute right-0 top-full pt-2 z-50 pointer-events-none opacity-0 group-hover/proj:pointer-events-auto group-hover/proj:opacity-100 transition-opacity duration-150">
                    <div class="w-56 bg-[#2a4d6e] border border-white/15 rounded-xl shadow-2xl overflow-hidden">
                        <a href="https://escalift.io" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-3 px-4 py-3 text-gray-200 hover:bg-white/10 transition-colors no-underline border-b border-white/10">
                            <img src="/images/escalift-logo.svg" alt="" class="w-6 h-6 rounded-md flex-none" />
                            <div>
                                <div class="text-sm font-medium leading-tight">Escalift</div>
                                <div class="text-xs text-gray-400 mt-0.5">VT community &amp; forum</div>
                            </div>
                        </a>
                        <a href="https://counterweight.ghost.io/" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-3 px-4 py-3 text-gray-200 hover:bg-white/10 transition-colors no-underline">
                            <picture>
                                <source srcset="/images/counterweight-logo.webp" type="image/webp" />
                                <img src="/images/counterweight-logo.png" alt="" class="w-6 h-6 rounded-md flex-none" />
                            </picture>
                            <div>
                                <div class="text-sm font-medium leading-tight">Counterweight</div>
                                <div class="text-xs text-gray-400 mt-0.5">Industry newsletter</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Mobile menu toggle -->
        <details class="sm:hidden group relative">
            <summary class="flex items-center justify-center w-10 h-10 rounded-lg cursor-pointer list-none text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors" aria-label="Open menu">
                <!-- Hamburger when closed; X when open -->
                <svg class="w-6 h-6 group-open:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
                <svg class="w-6 h-6 hidden group-open:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </summary>
            <!-- Drop-down panel: full-width on mobile, anchored to the right of the toggle -->
            <nav class="absolute right-0 mt-2 w-64 max-w-[calc(100vw-1.5rem)] bg-[#355c7d] border border-white/15 rounded-2xl shadow-2xl overflow-hidden text-base">
                <a href="/" class="block px-5 py-3.5 text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors no-underline border-b border-white/10">Home</a>
                <a href="/healthtrail-medical/" class="block px-5 py-3.5 text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors no-underline border-b border-white/10">Health</a>
                <a href="/escalator-field-command/" class="block px-5 py-3.5 text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors no-underline border-b border-white/10">Escalator</a>
                <a href="/#financial" class="block px-5 py-3.5 text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors no-underline border-b border-white/10">Financial</a>
                <a href="/about/" class="block px-5 py-3.5 text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors no-underline border-b border-white/10">About</a>
                <a href="/#faq" class="block px-5 py-3.5 text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors no-underline border-b border-white/10">FAQ</a>
                <a href="/#contact" class="block px-5 py-3.5 text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors no-underline border-b border-white/10">Contact</a>
                <!-- Other Projects section in mobile menu -->
                <div class="px-5 pt-3 pb-1 text-xs text-gray-500 uppercase tracking-wider font-semibold">Other Projects</div>
                <a href="https://escalift.io" target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-3 px-5 py-3 text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors no-underline border-t border-white/10">
                    <img src="/images/escalift-logo.svg" alt="" class="w-5 h-5 rounded flex-none" />
                    <span>Escalift ↗</span>
                </a>
                <a href="https://counterweight.ghost.io/" target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-3 px-5 py-3 text-gray-200 hover:bg-white/10 active:bg-white/20 transition-colors no-underline border-t border-white/10">
                    <picture>
                        <source srcset="/images/counterweight-logo.webp" type="image/webp" />
                        <img src="/images/counterweight-logo.png" alt="" class="w-5 h-5 rounded flex-none" />
                    </picture>
                    <span>Counterweight ↗</span>
                </a>
            </nav>
        </details>
    </div>
</header>
