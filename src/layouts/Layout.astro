---
import '../../src/styles/globals.css';
import '@fontsource-variable/inter/wght.css';
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    twitterCard?: 'summary' | 'summary_large_image';
}

const SITE_URL = 'https://artificialigknorance.com';

const {
    title,
    description = "Escalator Field Command — iOS app for escalator mechanics: routes, Category 1 testing, SSPI compliance, inspections. Plus privacy-first apps for health, finance & more by Artificial Igknorance.",
    ogImage = SITE_URL + '/images/robot-mascot-transparent.png',
    twitterCard = 'summary_large_image'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : SITE_URL + ogImage;

// JSON-LD structured data graph. Escalator Field Command appears first and
// carries the most detail to bias search/Knowledge-Graph weighting toward it.
const structuredData = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Organization",
            "@id": SITE_URL + "/#organization",
            "name": "Artificial Igknorance",
            "url": SITE_URL,
            "logo": {
                "@type": "ImageObject",
                "url": SITE_URL + "/images/robot-mascot-transparent.png"
            },
            "founder": {
                "@type": "Person",
                "name": "Mike Dangerfield"
            },
            "sameAs": [
                "https://twitter.com/igknorance",
                "https://x.com/igknorance"
            ],
            "contactPoint": {
                "@type": "ContactPoint",
                "email": "Info@artificialigknorance.com",
                "contactType": "customer support"
            }
        },
        {
            "@type": "WebSite",
            "@id": SITE_URL + "/#website",
            "url": SITE_URL,
            "name": "Artificial Igknorance",
            "description": "Privacy-first iOS apps — escalator industry tools, health tracking, precious metals, and bill scanning. 100% on-device.",
            "publisher": { "@id": SITE_URL + "/#organization" },
            "inLanguage": "en-US"
        },
        {
            "@type": "MobileApplication",
            "@id": SITE_URL + "/#escalator-field-command",
            "name": "Escalator Field Command",
            "alternateName": "Escalator Field Command for iOS",
            "description": "Built for escalator mechanics. Manage maintenance routes, Category 1 testing, SSPI compliance, and inspection documentation — all in one offline-first interface designed for real-world field use.",
            "applicationCategory": "BusinessApplication",
            "applicationSubCategory": "Productivity",
            "operatingSystem": "iOS 17+",
            "url": "https://apps.apple.com/us/app/escalator-field-command/id6756789866",
            "downloadUrl": "https://apps.apple.com/us/app/escalator-field-command/id6756789866",
            "installUrl": "https://apps.apple.com/us/app/escalator-field-command/id6756789866",
            "image": SITE_URL + "/images/escalator-field-command-icon.webp",
            "screenshot": SITE_URL + "/images/escalator-field-command-icon.webp",
            "publisher": { "@id": SITE_URL + "/#organization" },
            "creator": { "@id": SITE_URL + "/#organization" },
            "author": { "@id": SITE_URL + "/#organization" },
            "offers": {
                "@type": "Offer",
                "price": "0",
                "priceCurrency": "USD",
                "availability": "https://schema.org/InStock"
            },
            "inLanguage": "en-US",
            "keywords": "escalator mechanic, escalator maintenance, Category 1 testing, SSPI compliance, escalator inspection, field service app, escalator field command, iOS escalator app, escalator technician tools"
        },
        {
            "@type": "MobileApplication",
            "@id": SITE_URL + "/#healthtrail-medical",
            "name": "HealthTrail Medical",
            "description": "Your family's digital medical memory. Visual timeline of medical events, medications, and milestones with AI medication scanning, vaccine tracking, and 100% private local storage.",
            "applicationCategory": "HealthApplication",
            "operatingSystem": "iOS",
            "url": "https://apps.apple.com/us/app/healthtrail-medical/id6758072258",
            "downloadUrl": "https://apps.apple.com/us/app/healthtrail-medical/id6758072258",
            "image": SITE_URL + "/images/healthtrail-medical-icon.webp",
            "publisher": { "@id": SITE_URL + "/#organization" },
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
            "inLanguage": "en-US"
        },
        {
            "@type": "MobileApplication",
            "@id": SITE_URL + "/#snapledger",
            "name": "SnapLedger",
            "description": "Snap a photo of any bill and let AI extract the details. Track subscriptions by category, monitor household expenses, and spot trends across months.",
            "applicationCategory": "FinanceApplication",
            "operatingSystem": "iOS",
            "url": "https://apps.apple.com/ca/app/snapledger-%C3%B8/id6759497982",
            "downloadUrl": "https://apps.apple.com/ca/app/snapledger-%C3%B8/id6759497982",
            "image": SITE_URL + "/images/snapledger-icon.webp",
            "publisher": { "@id": SITE_URL + "/#organization" },
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
            "inLanguage": "en-US"
        },
        {
            "@type": "MobileApplication",
            "@id": SITE_URL + "/#copper-watcher",
            "name": "Copper Watcher (Cu)",
            "description": "Live copper spot price, ETFs, futures, and a scrap calculator. Portfolio tracking, price alerts, What If calculator with S&P 500 comparison, 10 currencies.",
            "applicationCategory": "FinanceApplication",
            "operatingSystem": "iOS",
            "url": "https://apps.apple.com/us/app/copper-watcher-cu/id6757655923",
            "downloadUrl": "https://apps.apple.com/us/app/copper-watcher-cu/id6757655923",
            "image": SITE_URL + "/images/copper-watcher-icon.webp",
            "publisher": { "@id": SITE_URL + "/#organization" },
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
            "inLanguage": "en-US"
        },
        {
            "@type": "MobileApplication",
            "@id": SITE_URL + "/#gold-watcher",
            "name": "Gold Watcher (Au)",
            "description": "Live gold spot price, ETFs, futures, and the gold/silver ratio. Portfolio tracking, price alerts, karat calculator for jewellers, What If calculator with S&P 500 comparison.",
            "applicationCategory": "FinanceApplication",
            "operatingSystem": "iOS",
            "url": "https://apps.apple.com/us/app/gold-watcher-au/id6758283387",
            "downloadUrl": "https://apps.apple.com/us/app/gold-watcher-au/id6758283387",
            "image": SITE_URL + "/images/gold-watcher-icon.webp",
            "publisher": { "@id": SITE_URL + "/#organization" },
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
            "inLanguage": "en-US"
        },
        {
            "@type": "MobileApplication",
            "@id": SITE_URL + "/#silver-watcher",
            "name": "Silver Watcher (Ag)",
            "description": "Live silver spot price, ETFs, futures. Portfolio tracking, price alerts, and What If calculator with S&P 500 comparison across 10 currencies.",
            "applicationCategory": "FinanceApplication",
            "operatingSystem": "iOS",
            "url": "https://apps.apple.com/us/app/silver-watcher-ag/id6760270695",
            "downloadUrl": "https://apps.apple.com/us/app/silver-watcher-ag/id6760270695",
            "image": SITE_URL + "/images/silver-watcher-icon.webp",
            "publisher": { "@id": SITE_URL + "/#organization" },
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
            "inLanguage": "en-US"
        }
    ]
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>{title}</title>
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />

        <!-- Canonical URL -->
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:image" content={absoluteOgImage} />
        <meta property="og:site_name" content="Artificial Igknorance" />
        <meta property="og:locale" content="en_US" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content={twitterCard} />
        <meta name="twitter:site" content="@igknorance" />
        <meta name="twitter:creator" content="@igknorance" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={absoluteOgImage} />

        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="preload" as="font" type="font/woff2" href={interWoff2} crossorigin />

        <!-- Structured data: Organization + WebSite + every iOS app, with Escalator Field Command first/most detailed -->
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

        <!-- Slot for per-page additions (extra structured data, preloads, etc.) -->
        <slot name="head" />
    </head>
    <body class="antialiased text-white bg-complementary">
        <div class="flex flex-col min-h-screen px-6 bg-noise sm:px-12">
            <div class="flex flex-col w-full max-w-5xl mx-auto grow">
                <Header />
                <main class="grow"><slot /></main>
                <Footer />
            </div>
        </div>
    </body>
</html>
