---
import '../../src/styles/globals.css';
import '@fontsource-variable/inter/wght.css';
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
    description?: string;
    /**
     * Title shown in social-share previews (iMessage, Slack, Twitter, Facebook,
     * etc.). Decoupled from `title` because the HTML `<title>` is tuned for
     * SEO (Escalator-led on the homepage), while the share card should pitch
     * the brand. Defaults to `title` when not set.
     */
    ogTitle?: string;
    /** Description shown in social-share previews. Defaults to `description`. */
    ogDescription?: string;
    ogImage?: string;
    twitterCard?: 'summary' | 'summary_large_image';
    /**
     * App Store ID for the iOS Smart App Banner. When set, iPhone Safari shows
     * a native install banner at the top of the page. Defaults to Escalator
     * Field Command (the priority app). Pass an empty string to suppress.
     */
    smartAppId?: string;
    /**
     * ISO date this page first went live. Used for `datePublished` in the
     * page's WebPage JSON-LD. Defaults to the brand-site relaunch date.
     */
    datePublished?: string;
    /**
     * Schema.org `@id` of the entity this page is primarily about — typically
     * a `MobileApplication`. Tells Google "this page is about that app" so
     * the WebPage and the app schema are linked. Optional.
     */
    mainEntityId?: string;
}

const SITE_URL = 'https://artificialigknorance.com';

const {
    title,
    description = "Escalator Field Command — iOS app for escalator mechanics: routes, Category 1 testing, SSPI compliance, inspections. Plus privacy-first apps for health, finance & more by Artificial Igknorance.",
    ogTitle,
    ogDescription,
    ogImage = SITE_URL + '/images/robot-mascot-transparent.png',
    twitterCard = 'summary_large_image',
    smartAppId = '6756789866',
    datePublished = '2026-04-15',
    mainEntityId
} = Astro.props;

// Social-share title/description default to the SEO title/description but can
// be overridden per-page so that share previews can lead with brand messaging
// instead of an SEO-tuned title.
const shareTitle = ogTitle ?? title;
const shareDescription = ogDescription ?? description;

// dateModified updates with each build. Google reads this as a freshness signal.
const dateModified = new Date().toISOString();

const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : SITE_URL + ogImage;

