---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>{title}</title>
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />

        <!-- Google Search Console verification -->
        <meta name="google-site-verification" content="neOvBtGtl_dR2NzEoMfxv5I98EstvKS8z9105mphEF8" />

        <!-- iOS Smart App Banner: shows native install banner in iPhone Safari -->
        {smartAppId && <meta name="apple-itunes-app" content={`app-id=${smartAppId}`} />}

        <!-- Canonical URL -->
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={shareTitle} />
        <meta property="og:description" content={shareDescription} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:image" content={absoluteOgImage} />
        <meta property="og:site_name" content="Artificial Igknorance" />
        <meta property="og:locale" content="en_US" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content={twitterCard} />
        <meta name="twitter:site" content="@igknorance" />
        <meta name="twitter:creator" content="@igknorance" />
        <meta name="twitter:title" content={shareTitle} />
        <meta name="twitter:description" content={shareDescription} />
        <meta name="twitter:image" content={absoluteOgImage} />

        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

        <!-- Mobile browser chrome — matches site background -->
        <meta name="theme-color" content="#355c7d" />
        <link rel="preload" as="font" type="font/woff2" href={interWoff2} crossorigin />
        <!-- Preload the hero mascot: it's the largest above-the-fold image, so this lifts LCP / page-speed score -->
        <link rel="preload" as="image" href="/images/robot-mascot-transparent.png" />

        <!-- Structured data: Organization + WebSite + every iOS app, with Escalator Field Command first/most detailed -->
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

        <!-- Slot for per-page additions (extra structured data, preloads, etc.) -->
        <slot name="head" />
    </head>
    <body class="antialiased text-white bg-complementary">
        <div class="flex flex-col min-h-screen px-6 bg-noise sm:px-12">
            <div class="flex flex-col w-full max-w-5xl mx-auto grow">
                <Header />
                <main class="grow"><slot /></main>
                <Footer />
            </div>
        </div>
        <!-- Cloudflare Web Analytics -->
        <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "8612aa99a1424f8eb510657090672462"}'></script>
    </body>
</html>
